# ── Email (Resend) ──────────────────────────────────────────────────────────
# Restricted "sending" Resend API key for the verified mycareerpathshala.com domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Auth/security mail (login OTP, email verification & change, password change).
EMAIL_FROM_AUTH=My Career Pathshala <noreply@mycareerpathshala.com>
# Everything else (application & counselling status updates, notifications).
EMAIL_FROM_ADMISSION=My Career Pathshala Admissions <admission@mycareerpathshala.com>
# Dev only: funnel every outgoing email to one inbox. Leave unset in production.
# EMAIL_DEV_OVERRIDE=you@example.com

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Strapi ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=https://strapi.example.com
STRAPI_API_TOKEN=your-strapi-api-token
